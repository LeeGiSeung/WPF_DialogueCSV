<Window x:Class="WPF_DialogueCSV.DialogueEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dialogue Editor" Height="950" Width="1250">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dialogue Professional Editor" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Grid.Row="0"/>

        <GroupBox Header="[Alter] 데이터 조회 및 선택" Grid.Row="1" Margin="0,0,0,15" BorderBrush="Gray">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <Label Content="대상 파일:" VerticalAlignment="Center" FontWeight="Bold"/>
                    <ComboBox x:Name="csvList" Width="150" Margin="5,0" SelectionChanged="csvList_SelectionChanged">
                        <ComboBoxItem Content="Normal"/>
                        <ComboBoxItem Content="Auto"/>
                        <ComboBoxItem Content="Choice"/>
                        <ComboBoxItem Content="Cinematic"/>
                    </ComboBox>
                    <Button Content="새로고침" Width="80" Click="btnRefresh_Click" Background="AliceBlue"/>
                    <TextBlock Text=" * 수정하려면 표에서 행을 선택하세요." Foreground="Blue" VerticalAlignment="Center" Margin="20,0,0,0"/>
                </StackPanel>

                <DataGrid x:Name="dgDisplay" Grid.Row="1" Margin="5" AutoGenerateColumns="True" 
                          IsReadOnly="True" SelectionMode="Single" VerticalScrollBarVisibility="Auto"
                          SelectionChanged="dgDisplay_SelectionChanged" Background="#F0F0F0"/>
            </Grid>
        </GroupBox>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="[Editor] 데이터 입력 및 수정" BorderBrush="DodgerBlue" BorderThickness="2">
                    <StackPanel Margin="10">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Content="ID (순수 숫자):" Grid.Row="0" Grid.Column="0"/>
                            <TextBox x:Name="TxtID" Grid.Row="0" Grid.Column="1" Margin="2" Padding="3" Background="#FFF9E1"/>

                            <Label Content="Speaker:" Grid.Row="0" Grid.Column="2"/>
                            <Grid Grid.Row="0" Grid.Column="3" Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ComboSpeaker" Grid.Column="0" IsEditable="True"/>
                                <Button x:Name="btnPlaySound" Grid.Column="1" Content="▶" Width="30" Margin="2,0,0,0" 
            Click="btnPlaySound_Click" Background="LightGreen" ToolTip="사운드 재생"/>
                            </Grid>

                            <Label Content="Next UI Type:" Grid.Row="1" Grid.Column="0"/>
                            <ComboBox x:Name="ComboUIType" Grid.Row="1" Grid.Column="1" Margin="2" SelectionChanged="ComboUIType_SelectionChanged">
                                <ComboBoxItem Content="Normal"/>
                                <ComboBoxItem Content="Auto"/>
                                <ComboBoxItem Content="Choice"/>
                                <ComboBoxItem Content="Cinematic"/>
                                <ComboBoxItem Content="End"/>a
                            </ComboBox>

                            <Label Content="Event Type:" Grid.Row="1" Grid.Column="2"/>
                            <ComboBox x:Name="ComboEventType" Grid.Row="1" Grid.Column="3" Margin="2" IsEditable="True"/>

                            <Label Content="Directing Key:" Grid.Row="2" Grid.Column="0"/>
                            <TextBox x:Name="TxtDirectingKey" Grid.Row="2" Grid.Column="1" Margin="2" Padding="3"/>

                            <Label Content="Next ID (숫자):" Grid.Row="2" Grid.Column="2"/>
                            <TextBox x:Name="TxtNextID" Grid.Row="2" Grid.Column="3" Margin="2" Padding="3"/>
                        </Grid>

                        <Label Content="First Text" FontWeight="Bold"/>
                        <TextBox x:Name="TxtFirst" Height="50" Margin="0,0,0,5" TextWrapping="Wrap" AcceptsReturn="True"/>
                        <Label Content="Second Text" FontWeight="Bold"/>
                        <TextBox x:Name="TxtSecond" Height="50" Margin="0,0,0,10" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <GroupBox x:Name="ChoiceSection" Header="Choice 전용 설정" Visibility="Collapsed" Margin="0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Label Content="Choice Text" HorizontalAlignment="Center"/>
                                <Label Content="Answer ID (숫자)" Grid.Column="1" HorizontalAlignment="Center"/>
                                <TextBox x:Name="TxtChoice1" Grid.Row="1" Margin="2"/>
                                <TextBox x:Name="TxtAnswer1" Grid.Row="1" Grid.Column="1" Margin="2"/>
                                <TextBox x:Name="TxtChoice2" Grid.Row="2" Margin="2"/>
                                <TextBox x:Name="TxtAnswer2" Grid.Row="2" Grid.Column="1" Margin="2"/>
                                <TextBox x:Name="TxtChoice3" Grid.Row="3" Margin="2"/>
                                <TextBox x:Name="TxtAnswer3" Grid.Row="3" Grid.Column="1" Margin="2"/>
                                <TextBox x:Name="TxtChoice4" Grid.Row="4" Margin="2"/>
                                <TextBox x:Name="TxtAnswer4" Grid.Row="4" Grid.Column="1" Margin="2"/>
                            </Grid>
                        </GroupBox>

                        <Button Content="데이터 저장 (중복 시 수정 / 없으면 추가)" Height="50" FontWeight="Bold" Margin="0,10" Click="Button_Click" Background="#E1F5FE"/>
                        <Button Content="새로 만들기 (입력칸 비우기)" Height="30" Click="bntClear_Click"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>