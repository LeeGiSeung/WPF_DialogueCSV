<Window x:Class="WPF_DialogueCSV.DialogueEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dialogue Editor" Height="750" Width="600">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <StackPanel>
                <TextBlock Text="Dialogue Add Editor" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                <ComboBox x:Name="csvList" Grid.Row="2" Grid.Column="1" Margin="2" 
          SelectionChanged="ComboUIType_SelectionChanged">
                    <ComboBoxItem Content="Normal"/>
                    <ComboBoxItem Content="Auto"/>
                    <ComboBoxItem Content="Choice"/>
                    <ComboBoxItem Content="Cinematic"/>
                </ComboBox>

                <GroupBox Header="공통 정보" Margin="0,0,0,10">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="ID:" Grid.Row="0" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtID" Grid.Row="0" Grid.Column="1" Margin="2" Padding="3" TextChanged="TxtID_TextChanged"/>

                        <Label Content="Speaker:" Grid.Row="1" VerticalAlignment="Center"/>
                        <Grid Grid.Row="1" Grid.Column="1" Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="ComboSpeaker" Grid.Column="0"/>

                            <Button x:Name="btnPlaySound" Grid.Column="1" Content="▶" Width="30" 
            ToolTip="선택된 음성 들어보기" Click="btnPlaySound_Click" Height="22" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Label Content="Next UI Type:" Grid.Row="2" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ComboUIType" Grid.Row="2" Grid.Column="1" Margin="2" 
                                  SelectionChanged="ComboUIType_SelectionChanged"/>

                        <Label Content="Event Type:" Grid.Row="3" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ComboEventType" Grid.Row="3" Grid.Column="1" Margin="2"/>

                        <Label Content="Directing Key:" Grid.Row="4" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtDirectingKey" Grid.Row="4" Grid.Column="1" Margin="2" Padding="3"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="대사 내용" Margin="0,0,0,10">
                    <StackPanel Margin="5">
                        <Label Content="First Text:"/>
                        <TextBox x:Name="TxtFirst" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="2" VerticalScrollBarVisibility="Auto"/>
                        <Label Content="Second Text:"/>
                        <TextBox x:Name="TxtSecond" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="2" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="NextIDSection" Header="연결 정보 (Next ID)" Margin="0,0,0,10">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Next ID:" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtNextID" Grid.Column="1" Margin="2" Padding="3"/>
                    </Grid>
                </GroupBox>

                <GroupBox x:Name="ChoiceSection" Header="선택지 구성" Visibility="Collapsed" BorderBrush="DodgerBlue" Margin="0,0,0,10">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Choice Text" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <Label Content="Answer ID" Grid.Column="1" FontWeight="Bold" HorizontalAlignment="Center"/>

                        <TextBox x:Name="TxtChoice1" Grid.Row="1" Margin="2"/>
                        <TextBox x:Name="TxtAnswer1" Grid.Row="1" Grid.Column="1" Margin="2"/>

                        <TextBox x:Name="TxtChoice2" Grid.Row="2" Margin="2"/>
                        <TextBox x:Name="TxtAnswer2" Grid.Row="2" Grid.Column="1" Margin="2"/>

                        <TextBox x:Name="TxtChoice3" Grid.Row="3" Margin="2"/>
                        <TextBox x:Name="TxtAnswer3" Grid.Row="3" Grid.Column="1" Margin="2"/>

                        <TextBox x:Name="TxtChoice4" Grid.Row="4" Margin="2"/>
                        <TextBox x:Name="TxtAnswer4" Grid.Row="4" Grid.Column="1" Margin="2"/>
                    </Grid>
                </GroupBox>

                <Button Content="데이터 저장 및 행 추가" Height="45" FontWeight="Bold" Margin="0,10,0,10" Click="Button_Click"/>
                <Button x:Name="btnClear" Content="초기화" Height="30" Click="bntClear_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>