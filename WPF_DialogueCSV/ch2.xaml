<Window x:Class="WPF_DialogueCSV.ch2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_DialogueCSV"
        mc:Ignorable="d"
        Title="스택패널" Height="450" Width="800">
    <StackPanel Orientation="Vertical">
        <Button HorizontalAlignment="Left" Content="버튼1"></Button>
        <Button HorizontalAlignment="Right" Content="버튼2"></Button>
        <Button HorizontalAlignment="Center" Content="버튼3"></Button>
        <Button HorizontalAlignment="Stretch" Content="버튼4"></Button>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Margin="10" HorizontalAlignment="Left" Content="1-1"></Button>
            <Button Margin="10" HorizontalAlignment="Right" Content="2-2"></Button>
            <Button Margin="10" HorizontalAlignment="Center" Content="3-3"></Button>
            <Button Margin="10" HorizontalAlignment="Stretch" Content="4-4"></Button>
        </StackPanel>
    </StackPanel>
</Window>
