<Window x:Class="WPF_DialogueCSV.ch3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_DialogueCSV"
        mc:Ignorable="d"
        Title="ch3" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Button Grid.Row ="0" Grid.Column ="0" Content="버튼 0 0" Width="100" />
        <Button Grid.Row ="0" Grid.Column ="1" Content="버튼 0 1"/>
        <Button Grid.Row ="0" Grid.Column ="2" Content="버튼 0 2"/>
        <Button Grid.Row ="0" Grid.Column ="3" Content="버튼 0 3"/>

        <Button Grid.RowSpan="2" Grid.Row ="1" Grid.Column ="0" Content="버튼 1 0" Width="100" />
        
        <Button Grid.Row ="1" Grid.Column ="1" Content="버튼 1 1"/>
        <Button Grid.ColumnSpan="2" Grid.Row ="1" Grid.Column ="2" Content="버튼 1 2"/>

    </Grid>
</Window>
